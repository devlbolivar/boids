# App configuration
ENVIRONMENT=development
SECRET_KEY=generate_a_secure_random_key_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration (PostgreSQL with asyncpg)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=boids_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/boids_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Master Encryption Key (Used for wrapping/deriving per-tenant keys if needed, or default encryption)
# Must be a 32-byte url-safe base64-encoded key for cryptography.fernet
MASTER_ENCRYPTION_KEY=3k4b5d6e7f8g9h0i1j2k3l4m5n6o7p8q9r0s1t2u3v4=

# Apollo.io API Key (global shared plan — tenants can override via api_keys_enc)
# Required for the Lead Finder Agent. Leave empty to skip real Apollo calls.
APOLLO_API_KEY=
